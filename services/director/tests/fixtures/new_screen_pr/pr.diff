+"use client";
+
+import { Shell } from "@/components/Shell";
+
+const ITEMS = [
+  { id: "n1", who: "Anna", what: "mentioned you on LOP-103", when: "today" },
+  { id: "n2", who: "Marcus", what: "assigned you LOP-101", when: "today" },
+  { id: "n3", who: "Sam", what: "commented on LOP-104", when: "yesterday" },
+];
+
+export default function InboxPage() {
+  return (
+    <Shell>
+      <h2 className="page">Inbox</h2>
+      <p className="subtle">Mentions and assignments.</p>
+      <ul className="inbox-list" data-testid="inbox">
+        {ITEMS.map((n) => (
+          <li key={n.id} className="inbox-item" data-notification={n.id}>
+            <strong>{n.who}</strong> {n.what}
+            <span className="when">{n.when}</span>
+          </li>
+        ))}
+      </ul>
+    </Shell>
+  );
+}
