 import { TicketCard } from "./TicketCard";
 import type { Ticket } from "@/lib/types";

 interface Props {
   title: string;
   tickets: Ticket[];
 }

 export function BoardColumn({ title, tickets }: Props) {
   return (
     <section className="board-column" data-testid={`column-${title.toLowerCase().replace(/\s+/g, "-")}`}>
-      <h3 className="board-column-title">{title}</h3>
+      <h3 className="board-column-title">
+        {title} <span className="board-column-count" data-testid="column-count">({tickets.length})</span>
+      </h3>
       <ol className="board-column-list">
         {tickets.map((t) => (
           <TicketCard key={t.id} ticket={t} />
         ))}
       </ol>
     </section>
   );
 }
